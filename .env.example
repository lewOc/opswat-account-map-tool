ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# For internal hosted testing, this can be left blank and users can enter
# their Anthropic key in the app.

# Optional runtime overrides
ACCOUNT_MAP_OUTPUT_DIR=outputs/account_maps
DECK_OUTPUT_DIR=outputs/decks
DIAGRAM_OUTPUT_DIR=outputs/diagrams
CAPABILITY_MAP_PATH=data/capability_map.json
PRESENTATION_TEMPLATE_PATH=templates/presentation_template.pptx
NODE_BIN=node

# Diagram assets
PRODUCT_ICON_DIR=assets/product_icons
OTHER_ICON_DIR=assets/other_icons
